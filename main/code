# ==============================================================================
# 3b) Hit-rate summary: how often mapped empirical power >= TARGET_POWER
#      (maps each replicate's induced N to nearest grid N within scenario x stability)
# ==============================================================================

if (!is.null(power_results) && nrow(power_results) > 0) {
  interp_required_N <- function(gridN, gridP, target_power = 0.80, enforce_monotone = TRUE) {
    okg <- is.finite(gridN) & is.finite(gridP)
    gridN <- as.numeric(gridN[okg]); gridP <- as.numeric(gridP[okg])
    if (length(gridN) < 2) return(NA_real_)
    
    ord <- order(gridN)
    gridN <- gridN[ord]; gridP <- gridP[ord]
    
    if (enforce_monotone) gridP <- cummax(gridP)
    
    # If never reaches target, return NA 
    if (max(gridP, na.rm = TRUE) < target_power) return(NA_real_)
    # If already above target at min gridN
    if (gridP[1] >= target_power) return(gridN[1])
    
    # Find first index where power >= target
    j <- which(gridP >= target_power)[1]
    if (is.na(j) || j == 1) return(gridN[1])
    
    # Linear interpolation between (j-1) and j
    N1 <- gridN[j - 1]; N2 <- gridN[j]
    P1 <- gridP[j - 1]; P2 <- gridP[j]
    if (!is.finite(P1) || !is.finite(P2) || P2 == P1) return(N2)
    
    N_star <- N1 + (target_power - P1) * (N2 - N1) / (P2 - P1)
    as.numeric(N_star)
  }
  
  interp_power_at_N <- function(N_vec, gridN, gridP, enforce_monotone = TRUE) {
    # Interpolate power at arbitrary N values using approx().
    
    okg <- is.finite(gridN) & is.finite(gridP)
    gridN <- as.numeric(gridN[okg])
    gridP <- as.numeric(gridP[okg])
    
    if (length(gridN) < 2) {
      return(list(power = rep(NA_real_, length(N_vec)), N_used = rep(NA_integer_, length(N_vec))))
    }
    
    ord <- order(gridN)
    gridN <- gridN[ord]
    gridP <- gridP[ord]
    
    # Monotonicity 
    if (enforce_monotone) {
      gridP <- cummax(gridP)
    }
    
    # approx() needs unique x values
    dup <- duplicated(gridN)
    if (any(dup)) {
      gridN_u <- gridN[!dup]
      gridP_u <- gridP[!dup]
      gridN <- gridN_u
      gridP <- gridP_u
    }
    
    # Interpolate/extrapolate
    N_vec_num <- as.numeric(N_vec)
    p_hat <- approx(x = gridN, y = gridP, xout = N_vec_num,
                    rule = 2, ties = "ordered")$y
    
    list(power = p_hat, N_used = as.integer(round(N_vec_num)))
  }
  
  
  message("\n============================================================")
  message("HIT-RATE SUMMARY: Pr(empirical power >= TARGET_POWER) by stability")
  message("(Power is mapped via nearest N on the sparse grid within scenario x stability)")
  message("============================================================")
  
  hit_rows <- list()
  hh <- 1
  
  for (sc in scenarios) {
    sc_dat <- pilot_results[pilot_results$scenario == sc, , drop = FALSE]
    stabs <- c(unique(sc_dat$stable_name), "rct")
    
    for (st in stabs) {
      
      # Induced N values across pilot replicates for this (scenario, stability)
      if (st == "rct") {
        # One N_rct per pilot replicate; sc_dat has repeated rows per rep_id x stability
        N_induced <- tapply(sc_dat$N_rct, sc_dat$rep_id, function(z) z[1])
        N_induced <- as.numeric(N_induced)
      } else {
        N_induced <- sc_dat$N_proposed[sc_dat$stable_name == st]
        N_induced <- as.numeric(N_induced)
      }
      N_induced <- N_induced[is.finite(N_induced)]
      if (length(N_induced) == 0) next
      
      grd <- power_results[power_results$scenario == sc, , drop = FALSE]
      if (nrow(grd) == 0) next
      
      # if duplicates exist, collapse:
      grd <- aggregate(cbind(power, success_rate) ~ N, data = grd, FUN = mean)
      
      gridN <- as.numeric(grd$N)
      gridP <- as.numeric(grd$power)
      ord <- order(gridN)
      gridN <- gridN[ord]; gridP <- gridP[ord]
      N_req <- interp_required_N(gridN, gridP, target_power = TARGET_POWER, enforce_monotone = TRUE)
      
      mapped <- interp_power_at_N(N_induced, gridN, gridP, enforce_monotone = TRUE)
      p_map <- mapped$power
      
      ok <- is.finite(p_map)
      n_reps <- sum(ok)
      n_hit  <- sum(p_map[ok] >= TARGET_POWER)
      
      hit_rows[[hh]] <- data.frame(
        scenario = sc,
        stable_name = st,
        n_reps = n_reps,
        n_hit = n_hit,
        hit_rate = ifelse(n_reps > 0, n_hit / n_reps, NA_real_),
        N_req_interp = N_req,
        stringsAsFactors = FALSE
      )
      hh <- hh + 1
    }
  }
  
  hit_summary <- if (length(hit_rows) > 0) do.call(rbind, hit_rows) else NULL
  
  if (!is.null(hit_summary)) {
    for (sc in unique(hit_summary$scenario)) {
      message(sprintf("\n--- Scenario: %s ---", sc))
      tmp <- hit_summary[hit_summary$scenario == sc, , drop = FALSE]
      tmp <- tmp[order(tmp$stable_name), , drop = FALSE]
      for (i in 1:nrow(tmp)) {
        message(sprintf("  %-10s: hits=%d/%d  (hit_rate=%.3f)",
                        tmp$stable_name[i], tmp$n_hit[i], tmp$n_reps[i], tmp$hit_rate[i]))
      }
    }
    
    # Optionally save
    write.csv(hit_summary, "hit_rate_summary.csv", row.names = FALSE)
    message("\nSaved: hit_rate_summary.csv")
  } else {
    message("No hit-rate summary produced (no overlap between pilot_results and power_results).")
  }
  
} else {
  message("\nNo power_results available; cannot compute hit-rate summary.")
}

# ==============================================================================
# 4) Save results (optional)
