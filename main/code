# ==============================================================================
# Settings
# ==============================================================================
set.seed(123)

ALPHA_SIG    <- 0.05
TARGET_POWER <- 0.80

# Pilot replicates (outer loop) and bootstraps (inner)
PILOT_REPS <- 1000
B_REPS     <- 1000   
B_UCB      <- 1000   
NSIMS_POWER <- 2000

# UCB
P_UCB     <- 0.50
GAMMA_UCB <- 0.05

# Binary
TREAT_RATIO_BIN  <- 0.25
DELTA_TARGET_BIN <- log(2)
PILOT_BIN        <- 600

# Count 
TREAT_RATIO_CNT  <- 0.67
DELTA_TARGET_CNT <- log(0.5)
LAMBDA_BASE      <- 0.008 
PILOT_CNT        <- 5000  

# cont 
PILOT_cont        <- 350
TREAT_RATIO_cont  <- 0.36  
DELTA_TARGET_cont <- 1500
MU0_cont          <- 18000

# Stability specs
STABLE_SPECS <- list(
  list(name = "median",      method = "quantile",     q = 0.50),
  list(name = "q70",         method = "quantile",     q = 0.70),
  list(name = "q90",         method = "quantile",     q = 0.90),
  list(name = "mean",        method = "mean",         q = NA_real_),
  list(name = "ucb_median",  method = "ucb_quantile", q = NA_real_),
  list(name = "ucb_mean",    method = "ucb_mean",     q = NA_real_)
)

z_vals <- (qnorm(1 - ALPHA_SIG / 2) + qnorm(TARGET_POWER))^2

# ==============================================================================
# One-pilot runner functions (return N across stability choices + N_RCT)
# ==============================================================================
run_one_pilot_binary <- function(p0_baseline, rep_id) {
  pilot_data <- generate_causal_data_binary(
    n = PILOT_BIN,
    treat_ratio = TREAT_RATIO_BIN,
    Delta_target = DELTA_TARGET_BIN,
    p0_target = p0_baseline
  )
  if (is.null(pilot_data)) return(NULL)
  
  boot_idx <- make_boot_indices(n = nrow(pilot_data), B = B_REPS,
                                seed = 10000 + 1000*rep_id + as.integer(round(100*p0_baseline)))
  
  V_res <- compute_V_ok_binary_from_pilot(pilot_data, boot_idx, pilot_size = PILOT_BIN)
  V_ok <- V_res$V_ok
  if (length(V_ok) < 100) return(NULL)
  
  ucb_idx <- make_boot_indices(n = length(V_ok), B = B_UCB,
                               seed = 20000 + 1000*rep_id + as.integer(round(100*p0_baseline)))
  
  # RCT benchmark N
  delta <- DELTA_TARGET_BIN
  p1_target <- plogis(qlogis(p0_baseline) + DELTA_TARGET_BIN)
  var_logit_rct <- (1 / (TREAT_RATIO_BIN * p1_target * (1 - p1_target))) +
    (1 / ((1 - TREAT_RATIO_BIN) * p0_baseline * (1 - p0_baseline)))
  N_rct <- ceiling((z_vals * var_logit_rct) / (delta^2))
  
  sc_name <- paste0("binary_p0_", sprintf("%.2f", p0_baseline))
  
  out <- data.frame(
    rep_id = integer(0),
    scenario = character(0),
    stable_name = character(0),
    N_proposed = integer(0),
    V_stable = numeric(0),
    N_rct = integer(0),
    stringsAsFactors = FALSE
  )
  
  for (sp in STABLE_SPECS) {
    V_stable <- compute_V_stable(
      V_ok,
      method = sp$method,
      q_stable = ifelse(is.na(sp$q), 0.50, sp$q),
      p_ucb = P_UCB,
      gamma_ucb = GAMMA_UCB,
      B_ucb = B_UCB,
      ucb_idx = ucb_idx
    )
    if (!is.finite(V_stable)) next
    
    N_prop <- ceiling((z_vals * V_stable) / (delta^2))
    out <- rbind(out, data.frame(
      rep_id = rep_id,
      scenario = sc_name,
      stable_name = sp$name,
      N_proposed = as.integer(N_prop),
      V_stable = as.numeric(V_stable),
      N_rct = as.integer(N_rct),
      stringsAsFactors = FALSE
    ))
    
  }
  if (nrow(out) == 0) return(NULL)
  out
}

run_one_pilot_count <- function(rep_id) {
  pilot_data <- generate_causal_data_count(
    n = PILOT_CNT,
    treat_ratio = TREAT_RATIO_CNT,
    Delta_target = DELTA_TARGET_CNT,
    base_rate = LAMBDA_BASE
  )
  if (is.null(pilot_data)) return(NULL)
  
  boot_idx <- make_boot_indices(n = nrow(pilot_data), B = B_REPS, seed = 11000 + 1000*rep_id)
  
  V_res <- compute_V_ok_count_from_pilot(pilot_data, boot_idx, pilot_size = PILOT_CNT)
  V_ok <- V_res$V_ok
  if (length(V_ok) < 100) return(NULL)
  
  ucb_idx <- make_boot_indices(n = length(V_ok), B = B_UCB, seed = 21000 + 1000*rep_id)
  
  delta <- DELTA_TARGET_CNT
  lambda0 <- LAMBDA_BASE
  lambda1 <- exp(log(lambda0) + DELTA_TARGET_CNT)
  var_rct_unit <- (1 / (TREAT_RATIO_CNT * lambda1)) + (1 / ((1 - TREAT_RATIO_CNT) * lambda0))
  N_rct <- ceiling((z_vals * var_rct_unit) / (delta^2))
  
  out <- data.frame(
    rep_id = integer(0),
    scenario = character(0),
    stable_name = character(0),
    N_proposed = integer(0),
    V_stable = numeric(0),
    N_rct = integer(0),
    stringsAsFactors = FALSE
  )
  
  
  for (sp in STABLE_SPECS) {
    V_stable <- compute_V_stable(
      V_ok,
      method = sp$method,
      q_stable = ifelse(is.na(sp$q), 0.50, sp$q),
      p_ucb = P_UCB,
      gamma_ucb = GAMMA_UCB,
      B_ucb = B_UCB,
      ucb_idx = ucb_idx
    )
    if (!is.finite(V_stable)) next
    
    N_prop <- ceiling((z_vals * V_stable) / (delta^2))
    out <- rbind(out, data.frame(
      rep_id = rep_id,
      scenario = "count",
      stable_name = sp$name,
      N_proposed = as.integer(N_prop),
      V_stable = as.numeric(V_stable),
      N_rct = as.integer(N_rct),
      stringsAsFactors = FALSE
    ))
  }
  if (nrow(out) == 0) return(NULL)
  out
}

run_one_pilot_cont <- function(rep_id) {
  pilot_data <- generate_causal_data_cont(
    n = PILOT_cont,
    treat_ratio = TREAT_RATIO_cont,
    mu0 = MU0_cont,
    Delta_target = DELTA_TARGET_cont
  )
  if (is.null(pilot_data)) return(NULL)
  
  boot_idx <- make_boot_indices(n = nrow(pilot_data), B = B_REPS, seed = 13000 + 1000*rep_id)
  
  V_res <- compute_V_ok_cont_from_pilot(pilot_data, boot_idx, pilot_size = PILOT_cont)
  V_ok <- V_res$V_ok
  if (length(V_ok) < 100) return(NULL)
  
  ucb_idx <- make_boot_indices(n = length(V_ok), B = B_UCB, seed = 23000 + 1000*rep_id)
  
  delta <- DELTA_TARGET_cont
  
  sigma2_hat <- stats::var(pilot_data$y)
  if (!is.finite(sigma2_hat) || sigma2_hat <= 0) sigma2_hat <- 1
  V_rct_unit <- sigma2_hat * (1 / TREAT_RATIO_cont + 1 / (1 - TREAT_RATIO_cont))
  N_rct <- ceiling((z_vals * V_rct_unit) / (delta^2))
  
  out <- data.frame(
    rep_id = integer(0),
    scenario = character(0),
    stable_name = character(0),
    N_proposed = integer(0),
    V_stable = numeric(0),
    N_rct = integer(0),
    stringsAsFactors = FALSE
  )
  
  
  for (sp in STABLE_SPECS) {
    V_stable <- compute_V_stable(
      V_ok,
      method = sp$method,
      q_stable = ifelse(is.na(sp$q), 0.50, sp$q),
      p_ucb = P_UCB,
      gamma_ucb = GAMMA_UCB,
      B_ucb = B_UCB,
      ucb_idx = ucb_idx
    )
    if (!is.finite(V_stable)) next
    
    N_prop <- ceiling((z_vals * V_stable) / (delta^2))
    out <- rbind(out, data.frame(
      rep_id = rep_id,
      scenario = "cont",
      stable_name = sp$name,
      N_proposed = as.integer(N_prop),
      V_stable = as.numeric(V_stable),
      N_rct = as.integer(N_rct),
      stringsAsFactors = FALSE
    ))
    
  }
  if (nrow(out) == 0) return(NULL)
  out
}

