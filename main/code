# Continuous cost outcome
# ==============================================================================
generate_causal_data_cont <- function(n,
                                      treat_ratio = 131/364,
                                      conf_strength = 0.6,
                                      mu0 = 18354,
                                      Delta_target = 5000,
                                      sigma_y = 3000,
                                      df_t = 4) {
  x  <- rnorm(n)
  brain_mets <- rbinom(n, 1, 0.23)
  imp_ps     <- rbinom(n, 1, 0.11)
  comorb     <- rbinom(n, 1, 0.54)
  
  lin_base <- conf_strength * (0.7*x + 0.8*brain_mets + 1.0*imp_ps + 0.5*comorb)
  f_a0 <- function(a0) mean(safe_plogis(a0 + lin_base)) - treat_ratio
  a0 <- safe_uniroot(f_a0)
  if (!is.finite(a0)) return(NULL)
  
  ps <- safe_plogis(a0 + lin_base)
  if (is_bad_ps(ps)) return(NULL)
  t <- rbinom(n, 1, ps)
  
  mu_x <- mu0 + 1200*x + 3500*brain_mets + 4500*imp_ps + 2000*comorb + Delta_target * t
  
  sd_i <- sigma_y * exp(0.15*abs(x) + 0.10*brain_mets + 0.15*imp_ps)
  
  # Scale t errors to have variance sd_i^2
  eps <- rt(n, df = df_t) * (sd_i * sqrt((df_t - 2) / df_t))
  
  y <- mu_x + eps
  
  data.frame(id = 1:n, y = y, t = t, x = x,
             brain_mets = brain_mets, imp_ps = imp_ps, comorb = comorb)
}

get_stacked_variance_cont <- function(data) {
  mod_ps <- glm(t ~ x + brain_mets + imp_ps + comorb, data = data, family = binomial)
  alpha_hat <- coef(mod_ps)
  if (any(!is.finite(alpha_hat))) return(NA_real_)
  
  ps_h <- predict(mod_ps, type = "response")
  if (is_bad_ps(ps_h)) return(NA_real_)
  
  w <- ifelse(data$t == 1, 1 / ps_h, 1 / (1 - ps_h))
  if (any(!is.finite(w))) return(NA_real_)
  
  mod_msm <- suppressWarnings(glm(y ~ t, data = data, family = gaussian, weights = w))
  beta_hat <- coef(mod_msm)
  if (any(!is.finite(beta_hat))) return(NA_real_)
  
  theta <- c(alpha_hat, beta_hat)
  p_al <- length(alpha_hat)
  p_be <- length(beta_hat)
  p_tot <- p_al + p_be
  
  psi_joint <- function(th, dat) {
    al <- th[1:p_al]
    be <- th[(p_al + 1):(p_al + p_be)]
    
    X_ps <- model.matrix(~ x + brain_mets + imp_ps + comorb, data = dat)
    e_x <- safe_plogis(as.numeric(X_ps %*% al))
    if (is_bad_ps(e_x)) return(matrix(NA_real_, nrow(dat), p_tot))
    u_alpha <- X_ps * (dat$t - e_x)
    
    W_x <- ifelse(dat$t == 1, 1 / e_x, 1 / (1 - e_x))
    if (any(!is.finite(W_x))) return(matrix(NA_real_, nrow(dat), p_tot))
    
    X_msm <- model.matrix(~ t, data = dat)
    mu <- as.numeric(X_msm %*% be)
    if (any(!is.finite(mu))) return(matrix(NA_real_, nrow(dat), p_tot))
    
    u_beta <- X_msm * W_x * (dat$y - mu)
    cbind(u_alpha, u_beta)
  }
  
  n_obs <- nrow(data)
  U <- psi_joint(theta, data)
  if (any(!is.finite(U))) return(NA_real_)
  
  Bmat <- (t(U) %*% U) / n_obs
  
  psi_sum <- function(th) colSums(psi_joint(th, data))
  A <- tryCatch(numDeriv::jacobian(psi_sum, theta), error = function(e) NULL)
  if (is.null(A) || any(!is.finite(A))) return(NA_real_)
  A <- A / n_obs
  
  invA <- tryCatch(solve(A), error = function(e) NULL)
  if (is.null(invA) || any(!is.finite(invA))) return(NA_real_)
  
  vcov_total <- (invA %*% Bmat %*% t(invA)) / n_obs
  
  # beta1 corresponds to t coefficient in MSM, which is 2nd element in beta_hat
  out <- vcov_total[p_al + 2, p_al + 2]
  if (!is.finite(out) || out <= 0) return(NA_real_)
  out
}

fit_and_test_stacked_cont <- function(data, alpha_sig = 0.05) {
  mod_ps <- glm(t ~ x + brain_mets + imp_ps + comorb, data = data, family = binomial)
