compute_V_ok_count_from_pilot <- function(pilot_data, boot_idx, pilot_size) {
  B_reps <- nrow(boot_idx)
  V_boot <- rep(NA_real_, B_reps)
  
  for (b in 1:B_reps) {
    smp <- pilot_data[boot_idx[b, ], , drop = FALSE]
