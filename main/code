summarize_N <- function(x) {
  x <- x[is.finite(x)]
  if (length(x) == 0) return(rep(NA_real_, 9))
  c(
    n = length(x),
    min = min(x),
    q10 = as.numeric(quantile(x, 0.10)),
    q25 = as.numeric(quantile(x, 0.25)),
    med = as.numeric(quantile(x, 0.50)),
    mean = mean(x),
    q75 = as.numeric(quantile(x, 0.75)),
    q90 = as.numeric(quantile(x, 0.90)),
    max = max(x)
  )
}

