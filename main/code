write.csv(pilot_results, "pilot_uncertainty_N_distributions.csv", row.names = FALSE)
if (!is.null(power_results)) write.csv(power_results, "power_validation_sparse_grid.csv", row.names = FALSE)

message("\n============================================================")
message("DONE.")
message("Saved:")
message("  - pilot_uncertainty_N_distributions.csv")
message("  - power_validation_sparse_grid.csv (if any)")
message("============================================================")

