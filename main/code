validate_power_binary <- function(N, p0_baseline,
                                  n_sims = 2000,
                                  treat_ratio = 0.25,
                                  Delta_target = log(2),
                                  alpha_sig = 0.05) {
  rejects <- logical(n_sims)
  oks     <- logical(n_sims)
  for (s in 1:n_sims) {
    dat <- generate_causal_data_binary(
      n = N, treat_ratio = treat_ratio, Delta_target = Delta_target, p0_target = p0_baseline
    )
    if (is.null(dat)) { rejects[s] <- FALSE; oks[s] <- FALSE; next }
    res <- tryCatch(fit_and_test_stacked_binary(dat, alpha_sig = alpha_sig),
                    error = function(e) list(reject = FALSE, ok = FALSE))
    rejects[s] <- res$reject
    oks[s]     <- res$ok
  }
  list(power = mean(rejects[oks]), success_rate = mean(oks))
}

