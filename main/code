safe_plogis <- function(eta) plogis(eta)

is_bad_ps <- function(p) any(!is.finite(p)) || any(p == 0) || any(p == 1)

logit_eps <- function(p, eps = 1e-12) qlogis(pmin(pmax(p, eps), 1 - eps))

safe_uniroot <- function(f, lo = -50, hi = 50, expand = 100, max_expand = 3) {
  f_lo <- f(lo); f_hi <- f(hi)
  k <- 0
  while ((!is.finite(f_lo) || !is.finite(f_hi) || f_lo * f_hi > 0) && k < max_expand) {
    lo <- lo - expand
    hi <- hi + expand
    f_lo <- f(lo); f_hi <- f(hi)
    k <- k + 1
  }
  if (!is.finite(f_lo) || !is.finite(f_hi) || f_lo * f_hi > 0) return(NA_real_)
  uniroot(f, interval = c(lo, hi))$root
}

make_boot_indices <- function(n, B, seed = NULL) {
  if (!is.null(seed)) set.seed(seed)
  idx <- matrix(NA_integer_, nrow = B, ncol = n)
  for (b in 1:B) idx[b, ] <- sample.int(n, size = n, replace = TRUE)
  idx
}

# ==============================================================================
# Bootstrap stability functionals (quantile / mean + UCB variants)
# ==============================================================================
bootstrap_ucb_functional <- function(V_ok, phi_fun,
                                     gamma_ucb = 0.05,
                                     B_ucb = 1000,
                                     ucb_idx = NULL,
                                     seed_ucb = NULL) {
  V_ok <- V_ok[is.finite(V_ok)]
  n <- length(V_ok)
  if (n < 20) return(NA_real_)
  
  if (is.null(ucb_idx)) {
    if (!is.null(seed_ucb)) set.seed(seed_ucb)
    ucb_idx <- matrix(sample.int(n, size = n * B_ucb, replace = TRUE), nrow = B_ucb, ncol = n)
  } else {
    if (!is.matrix(ucb_idx)) stop("ucb_idx must be a matrix (B_ucb x n_ok).")
    if (ncol(ucb_idx) != n) stop("ucb_idx has wrong number of columns.")
    if (nrow(ucb_idx) != B_ucb) stop("ucb_idx has wrong number of rows.")
  }
  
  phi_star <- rep(NA_real_, B_ucb)
  for (k in 1:B_ucb) phi_star[k] <- phi_fun(V_ok[ucb_idx[k, ]])
  phi_star <- phi_star[is.finite(phi_star)]
  if (length(phi_star) < max(50, 0.2 * B_ucb)) return(NA_real_)
  
  as.numeric(stats::quantile(phi_star, probs = 1 - gamma_ucb, names = FALSE))
}

compute_V_stable <- function(V_ok,
                             method = c("quantile", "mean", "ucb_quantile", "ucb_mean"),
                             q_stable = 0.50,
                             p_ucb = 0.50,
                             gamma_ucb = 0.05,
                             B_ucb = 1000,
                             ucb_idx = NULL,
                             seed_ucb = NULL) {
  method <- match.arg(method)
  if (!is.numeric(V_ok) || length(V_ok) == 0) return(NA_real_)
  V_ok <- V_ok[is.finite(V_ok)]
  n <- length(V_ok)
  if (n < 10) return(NA_real_)
  
  if (method == "mean") {
    return(as.numeric(mean(V_ok)))
  }
  if (method == "quantile") {
    return(as.numeric(stats::quantile(V_ok, probs = q_stable, names = FALSE)))
  }
  if (method == "ucb_mean") {
    phi_fun <- function(v) mean(v)
    return(bootstrap_ucb_functional(V_ok, phi_fun,
                                    gamma_ucb = gamma_ucb, B_ucb = B_ucb,
                                    ucb_idx = ucb_idx, seed_ucb = seed_ucb))
  }
  # ucb_quantile
  phi_fun <- function(v) as.numeric(stats::quantile(v, probs = p_ucb, names = FALSE))
  return(bootstrap_ucb_functional(V_ok, phi_fun,
                                  gamma_ucb = gamma_ucb, B_ucb = B_ucb,
                                  ucb_idx = ucb_idx, seed_ucb = seed_ucb))
}

# ==============================================================================
# Binary outcome (dataset-conditional calibration)
# ==============================================================================
calibrate_alpha0 <- function(x, treat_ratio, conf_effect) {
  f <- function(a0) mean(safe_plogis(a0 + conf_effect * x)) - treat_ratio
  safe_uniroot(f)
}

calibrate_gamma0 <- function(x, p0_target, x_y_effect = 0.5) {
  f <- function(g0) mean(safe_plogis(g0 + x_y_effect * x)) - p0_target
  safe_uniroot(f)
}

calibrate_psi_for_msm_logOR <- function(x, gamma0, Delta_target, x_y_effect = 0.5, eps = 1e-12) {
  p0 <- mean(plogis(gamma0 + x_y_effect * x))
  if (!is.finite(p0)) return(NA_real_)
  logit_p0 <- logit_eps(p0, eps = eps)
  
  f <- function(psi) {
    p1 <- mean(plogis(gamma0 + x_y_effect * x + psi))
    if (!is.finite(p1)) return(NA_real_)
    (logit_eps(p1, eps = eps) - logit_p0) - Delta_target
  }
  
  lo <- -40; hi <- 40
  f_lo <- f(lo); f_hi <- f(hi)
  k <- 0
  while ((!is.finite(f_lo) || !is.finite(f_hi) || f_lo * f_hi > 0) && k < 8) {
    lo <- lo - 20
    hi <- hi + 20
    f_lo <- f(lo); f_hi <- f(hi)
    k <- k + 1
  }
  if (!is.finite(f_lo) || !is.finite(f_hi) || f_lo * f_hi > 0) return(NA_real_)
  uniroot(f, interval = c(lo, hi))$root
}

generate_causal_data_binary <- function(n,
                                        treat_ratio = 0.25,
                                        conf_effect = 0.8,
                                        Delta_target = log(2),
                                        p0_target = 0.03,
                                        x_y_effect = 0.5,
                                        eps_logit = 1e-12) {
  x <- rnorm(n)
  
  alpha0 <- calibrate_alpha0(x, treat_ratio = treat_ratio, conf_effect = conf_effect)
  if (!is.finite(alpha0)) return(NULL)
  
  ps <- safe_plogis(alpha0 + conf_effect * x)
  if (is_bad_ps(ps)) return(NULL)
  
  t <- rbinom(n, 1, ps)
  
  gamma0 <- calibrate_gamma0(x, p0_target = p0_target, x_y_effect = x_y_effect)
  if (!is.finite(gamma0)) return(NULL)
  
  psi <- calibrate_psi_for_msm_logOR(
    x, gamma0 = gamma0, Delta_target = Delta_target,
    x_y_effect = x_y_effect, eps = eps_logit
  )
  if (!is.finite(psi)) return(NULL)
  
  y0_prob <- safe_plogis(gamma0 + x_y_effect * x)
  y1_prob <- safe_plogis(gamma0 + x_y_effect * x + psi)
  if (any(!is.finite(y0_prob)) || any(!is.finite(y1_prob))) return(NULL)
  
  y0 <- rbinom(n, 1, y0_prob)
  y1 <- rbinom(n, 1, y1_prob)
  y  <- ifelse(t == 1, y1, y0)
  
  data.frame(id = 1:n, y = y, t = t, x = x)
}

get_stacked_variance_binary <- function(data) {
  mod_ps <- glm(t ~ x, data = data, family = binomial)
  alpha_hat <- coef(mod_ps)
  if (any(!is.finite(alpha_hat))) return(NA_real_)
  
  ps_h <- predict(mod_ps, type = "response")
  if (is_bad_ps(ps_h)) return(NA_real_)
  
  w <- ifelse(data$t == 1, 1 / ps_h, 1 / (1 - ps_h))
  if (any(!is.finite(w))) return(NA_real_)
  
  mod_msm <- suppressWarnings(glm(y ~ t, data = data, family = binomial, weights = w))
  beta_hat <- coef(mod_msm)
  if (any(!is.finite(beta_hat))) return(NA_real_)
  
  theta <- c(alpha_hat, beta_hat)  # (alpha0, alpha1, beta0, beta1)
  p_al <- length(alpha_hat)
  p_be <- length(beta_hat)
  p_tot <- p_al + p_be
  
  psi_joint <- function(th, dat) {
    al <- th[1:p_al]
    be <- th[(p_al + 1):(p_al + p_be)]
    
    X_mat <- cbind(1, dat$x)
    e_x <- safe_plogis(as.numeric(X_mat %*% al))
    if (is_bad_ps(e_x)) return(matrix(NA_real_, nrow(dat), p_tot))
    u_alpha <- X_mat * (dat$t - e_x)
    
    W_x <- ifelse(dat$t == 1, 1 / e_x, 1 / (1 - e_x))
    if (any(!is.finite(W_x))) return(matrix(NA_real_, nrow(dat), p_tot))
    
    T_mat <- cbind(1, dat$t)
    mu <- safe_plogis(as.numeric(T_mat %*% be))
    if (any(!is.finite(mu))) return(matrix(NA_real_, nrow(dat), p_tot))
    
    u_beta <- T_mat * W_x * (dat$y - mu)
    cbind(u_alpha, u_beta)
  }
  
  n_obs <- nrow(data)
  U <- psi_joint(theta, data)
  if (any(!is.finite(U))) return(NA_real_)
  
  Bmat <- (t(U) %*% U) / n_obs
  
  psi_sum <- function(th) colSums(psi_joint(th, data))
  A <- tryCatch(numDeriv::jacobian(psi_sum, theta), error = function(e) NULL)
  if (is.null(A) || any(!is.finite(A))) return(NA_real_)
  A <- A / n_obs
  
  invA <- tryCatch(solve(A), error = function(e) NULL)
  if (is.null(invA) || any(!is.finite(invA))) return(NA_real_)
  
  vcov_total <- (invA %*% Bmat %*% t(invA)) / n_obs
  out <- vcov_total[p_al + 2, p_al + 2]
  if (!is.finite(out) || out <= 0) return(NA_real_)
  out
}

fit_and_test_stacked_binary <- function(data, alpha_sig = 0.05) {
  mod_ps <- glm(t ~ x, data = data, family = binomial)
  ps_h <- predict(mod_ps, type = "response")
  if (is_bad_ps(ps_h)) return(list(reject = FALSE, ok = FALSE))
  
  w <- ifelse(data$t == 1, 1 / ps_h, 1 / (1 - ps_h))
  if (any(!is.finite(w))) return(list(reject = FALSE, ok = FALSE))
  
  mod_msm <- suppressWarnings(glm(y ~ t, data = data, family = binomial, weights = w))
  beta_hat <- coef(mod_msm)
  if (any(!is.finite(beta_hat))) return(list(reject = FALSE, ok = FALSE))
  
  v_beta1 <- get_stacked_variance_binary(data)
  if (!is.finite(v_beta1)) return(list(reject = FALSE, ok = FALSE))
  
  z <- beta_hat["t"] / sqrt(v_beta1)
  crit <- qnorm(1 - alpha_sig / 2)
  list(reject = is.finite(z) && abs(z) > crit, ok = TRUE)
}

compute_V_ok_binary_from_pilot <- function(pilot_data, boot_idx, pilot_size) {
  B_reps <- nrow(boot_idx)
  V_boot <- rep(NA_real_, B_reps)
  
  for (b in 1:B_reps) {
    boot_sample <- pilot_data[boot_idx[b, ], , drop = FALSE]
    if (length(unique(boot_sample$t)) < 2) next
    if (length(unique(boot_sample$y)) < 2) next
    v_hat <- tryCatch(get_stacked_variance_binary(boot_sample), error = function(e) NA_real_)
    if (is.finite(v_hat)) V_boot[b] <- pilot_size * v_hat
  }
  V_ok <- V_boot[is.finite(V_boot)]
  list(V_ok = V_ok, V_boot = V_boot)
}

# ==============================================================================
# Count outcome (Poisson/log link)
# ==============================================================================
generate_causal_data_count <- function(n,
                                       treat_ratio = 0.67,
                                       conf_effect = 0.5,
                                       Delta_target = log(0.53),
                                       base_rate = 0.0006) {
  x <- rnorm(n)
  
  alpha0 <- calibrate_alpha0(x, treat_ratio = treat_ratio, conf_effect = conf_effect)
  if (!is.finite(alpha0)) return(NULL)
  
  ps <- safe_plogis(alpha0 + conf_effect * x)
  if (is_bad_ps(ps)) return(NULL)
  
  t <- rbinom(n, 1, ps)
  
  x_y_effect <- 0.3
  log_base <- log(base_rate)
  lambda0 <- exp(log_base + x_y_effect * x)
  lambda1 <- exp(log_base + x_y_effect * x + Delta_target)
  y <- ifelse(t == 1, rpois(n, lambda1), rpois(n, lambda0))
  
  data.frame(y = y, t = t, x = x)
}

