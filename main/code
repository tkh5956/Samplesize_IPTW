if (!is.null(power_results) && nrow(power_results) > 0) {
  
  # Helper: scenario-specific power interpolator using sparse grid
  power_at_N <- function(sc, N_vec, enforce_monotone = TRUE) {
    grd <- power_results[power_results$scenario == sc, , drop = FALSE]
    if (nrow(grd) < 2) return(rep(NA_real_, length(N_vec)))
    
    # collapse duplicates if any
    grd <- aggregate(power ~ N, data = grd, FUN = mean)
    
    gridN <- as.numeric(grd$N)
    gridP <- as.numeric(grd$power)
    ord <- order(gridN)
    gridN <- gridN[ord]
    gridP <- gridP[ord]
    
    if (enforce_monotone) gridP <- cummax(gridP)
    
    # approx power at arbitrary N (rule=2 -> extrapolate with endpoints)
    p_hat <- approx(x = gridN, y = gridP, xout = as.numeric(N_vec),
                    rule = 2, ties = "ordered")$y
    as.numeric(p_hat)
  }
  
  # Add columns
  pilot_results$power_Nprop <- NA_real_
  pilot_results$power_Nrct  <- NA_real_
  
  # Fill per scenario
  scenarios <- unique(pilot_results$scenario)
  for (sc in scenarios) {
    idx_sc <- which(pilot_results$scenario == sc)
    
    # power at proposed N (row-specific)
    pilot_results$power_Nprop[idx_sc] <- power_at_N(sc, pilot_results$N_proposed[idx_sc],
                                                    enforce_monotone = TRUE)
    
    # power at RCT N (row-specific)
    pilot_results$power_Nrct[idx_sc]  <- power_at_N(sc, pilot_results$N_rct[idx_sc],
                                                    enforce_monotone = TRUE)
  }
  
  message("\nAdded columns to pilot_results: power_Nprop (power at N_proposed), power_Nrct (power at N_rct).")
  
