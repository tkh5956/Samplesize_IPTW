# ==============================================================================
# 3) Power validation on a sparse grid derived from the N-distribution
# ==============================================================================
make_sparse_grid <- function(N_vec,
                             probs = seq(0.05, 0.95, by = 0.05),
                             include_minmax = TRUE,
                             include_mean = TRUE,
                             N_rct = NULL) {
  N_vec <- N_vec[is.finite(N_vec)]
  if (length(N_vec) == 0) return(data.frame(N = integer(0), grid_label = character(0)))
  
  out_list <- list()
  
  # quantiles
  q_raw <- as.numeric(stats::quantile(N_vec, probs = probs, names = FALSE))
  q_lab <- paste0("q", as.integer(100 * probs))
  for (i in seq_along(q_raw)) {
    out_list[[length(out_list) + 1]] <- data.frame(
      N = as.integer(ceiling(q_raw[i])),
      grid_label = q_lab[i],
      stringsAsFactors = FALSE
    )
  }
  
  if (include_minmax) {
    out_list[[length(out_list) + 1]] <- data.frame(N = as.integer(ceiling(min(N_vec))), grid_label = "min", stringsAsFactors = FALSE)
    out_list[[length(out_list) + 1]] <- data.frame(N = as.integer(ceiling(max(N_vec))), grid_label = "max", stringsAsFactors = FALSE)
  }
  
  if (include_mean) {
    out_list[[length(out_list) + 1]] <- data.frame(N = as.integer(ceiling(mean(N_vec))), grid_label = "mean", stringsAsFactors = FALSE)
  }
  
  if (!is.null(N_rct) && is.finite(N_rct)) {
    out_list[[length(out_list) + 1]] <- data.frame(N = as.integer(ceiling(N_rct)), grid_label = "rct_ref", stringsAsFactors = FALSE)
  }
  
  out <- do.call(rbind, out_list)
  
  out <- aggregate(grid_label ~ N, data = out, FUN = function(z) paste(sort(unique(z)), collapse = "+"))
  out <- out[order(out$N), , drop = FALSE]
  rownames(out) <- NULL
  out
}


